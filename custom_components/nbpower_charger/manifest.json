{
  "domain": "nbpower_charger",
  "name": "NBPower EV Charger (BLE)",
  "version": "1.3.0",
  "config_flow": true,
  "documentation": "https://github.com/Tamahome-M/nbpower-charger-ha",
  "issue_tracker": "https://github.com/Tamahome-M/nbpower-charger-ha/issues",
  "requirements": [
    "bleak>=0.21.1"
  ],
  "bluetooth": [
    {
      "connectable": true,
      "local_name": "NBP*"
    },
    {
      "connectable": true,
      "local_name": "NBPower*"
    }
  ],
  "dependencies": [
    "bluetooth"
  ],
  "codeowners": [
    "@Tamahome-M"
  ],
  "iot_class": "local_polling",
  "integration_type": "device"
}
